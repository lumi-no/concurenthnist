#include <iostream>
#include <vector>
#include <future>
#include <functional>

using namespace std;

template <typename T, typename R>
vector<R> parallel_map(function<R(T)> func,
                       const vector<T>& data)
{
    vector<future<R>> tasks;
    vector<R> result;

    for (int i = 0; i < data.size(); i++)
    {
        tasks.push_back(
            async(launch::async,
                  func,
                  data[i])
        );
    }

    for (int i = 0; i < tasks.size(); i++)
    {
        result.push_back(
            tasks[i].get()
        );
    }

    return result;
}

int square(int x)
{
    return x * x;
}

void print(const vector<int>& data,
           int index)
{
    if (index >= data.size())
    {
        return;
    }

    cout << data[index] << " ";

    print(data, index + 1);
}

int main()
{
    vector<int> data = {1, 2, 3, 4, 5};

    vector<int> result =
        parallel_map<int, int>(square, data);

    cout << "Original: ";
    print(data, 0);

    cout << endl;

    cout << "Result: ";
    print(result, 0);

    return 0;
}
