lock блокує доступ до спільної змінної counter, тобто в один момент часу тільки один потік може виконувати дію, а інший потік чекає, поки перший завершить роботу з 
counter. Через це збільшення не губляться. 
Мінуси цього підходу в тому що програма може працювати повільніше, потоки змушені чекати один одного, якщо неправильно використовувати lock, можна отримати deadlock, код стає складнішим, часте блокування зменшує перевагу багатопоточності. 

#include <iostream>
#include <thread>
#include <mutex>

using namespace std;

int counter = 0;
mutex mtx;

void increment_with_lock()
{
    for (int i = 0; i < 100000; i++)
    {
        mtx.lock();
        counter++;
        mtx.unlock();
    }
}

void increment_without_lock()
{
    for (int i = 0; i < 100000; i++)
    {
        counter++;
    }
}

int main()
{
    cout << "Без lock:" << endl;

    for (int test = 1; test <= 5; test++)
    {
        counter = 0;

        thread t1(increment_without_lock);
        thread t2(increment_without_lock);

        t1.join();
        t2.join();

        cout << "Test " << test
             << ": counter = "
             << counter << endl;
    }

    cout << endl;

    cout << "З lock:" << endl;

    for (int test = 1; test <= 5; test++)
    {
        counter = 0;

        thread t1(increment_with_lock);
        thread t2(increment_with_lock);

        t1.join();
        t2.join();

        cout << "Test " << test
             << ": counter = "
             << counter << endl;
    }

    return 0;
}
