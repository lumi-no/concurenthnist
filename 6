#include <iostream>
#include <vector>
#include <future>
#include <chrono>

using namespace std;
using namespace chrono;

int square(int x)
{
    return x * x;
}

vector<int> normal_map(const vector<int>& data)
{
    vector<int> result;

    for (int i = 0; i < data.size(); i++)
    {
        result.push_back(square(data[i]));
    }

    return result;
}

vector<int> parallel_map(const vector<int>& data)
{
    vector<future<int>> tasks;
    vector<int> result;

    for (int i = 0; i < data.size(); i++)
    {
        tasks.push_back(
            async(launch::async, square, data[i])
        );
    }

    for (int i = 0; i < tasks.size(); i++)
    {
        result.push_back(tasks[i].get());
    }

    return result;
}

