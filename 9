#include <iostream>
#include <vector>
#include <functional>

using namespace std;

using Step = function<vector<int>(vector<int>)>;

vector<int> pipeline(vector<int> data,
                     vector<Step> steps)
{
    for (int i = 0; i < steps.size(); i++)
    {
        data = steps[i](data);
    }

    return data;
}

vector<int> square_step(vector<int> data)
{
    vector<int> result;

    for (int i = 0; i < data.size(); i++)
    {
        result.push_back(data[i] * data[i]);
    }

    return result;
}

vector<int> filter_step(vector<int> data)
{
    vector<int> result;

    for (int i = 0; i < data.size(); i++)
    {
        if (data[i] > 10)
        {
            result.push_back(data[i]);
        }
    }

    return result;
}

vector<int> increment_step(vector<int> data)
{
    vector<int> result;

    for (int i = 0; i < data.size(); i++)
    {
        result.push_back(data[i] + 1);
    }

    return result;
}

void print(vector<int> data, int index)
{
    if (index >= data.size())
    {
        return;
    }

    cout << data[index] << " ";

    print(data, index + 1);
}

int main()
{
    vector<int> data = {1, 2, 3, 4, 5};

    vector<Step> steps =
    {
        square_step,
        filter_step,
        increment_step
    };

    vector<int> result =
        pipeline(data, steps);

    cout << "Result: ";

    print(result, 0);

    return 0;
}
